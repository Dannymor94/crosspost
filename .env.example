# Шаблон конфигурации. Скопировать в runtime/.env и заполнить значениями.
# Реальный .env НИКОГДА не коммитится (см. .gitignore).

# ── Общее ─────────────────────────────────────────────────────
APP_ENV=dev
STATE_DB_URL=sqlite:///runtime/state.db   # фаза A; дальше postgresql://...
MEDIA_TMP_DIR=runtime/media_tmp
MEDIA_TTL_HOURS=72

# ── Очередь ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Vault (шифрование сессий) ─────────────────────────────────
VAULT_DIR=runtime/vault
# ВНИМАНИЕ: ключ инжектится сюда из окружения/keyring/KMS, НЕ хранится файлом в runtime/.
# В .env допустимо лишь для локального dev; в проде — внешний секрет-стор.
VAULT_KEY=

# ── API-тир ───────────────────────────────────────────────────
# Telegram (Telethon, userbot)
TG_API_ID=
TG_API_HASH=
TG_SESSION_PATH=runtime/sessions/telegram.session
TG_TARGET_CHANNEL=

# ВКонтакте
VK_ACCESS_TOKEN=
VK_GROUP_ID=

# YouTube (Data API, OAuth)
YOUTUBE_CLIENT_SECRET_PATH=
YOUTUBE_TOKEN_PATH=runtime/sessions/youtube_token.json

# Telegraph
TELEGRAPH_ACCESS_TOKEN=

# ── Браузерный тир ────────────────────────────────────────────
BROWSER_PROFILES_DIR=runtime/profiles
BROWSER_HEADLESS=false
# Прокси на аккаунт задаются в профиле пользователя, не здесь

# ── Ретраи / breaker ──────────────────────────────────────────
RETRY_MAX_ATTEMPTS=3
BREAKER_COOLDOWN_MINUTES=60
